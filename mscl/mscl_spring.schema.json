{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MSCL-SPRING spec",
  "type": "object",
  "required": [
    "objects",
    "formula"
  ],
  "additionalProperties": false,
  "properties": {
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "enum": [
              "existing",
              "new"
            ]
          },
          "type": {
            "type": [
              "string",
              "null"
            ]
          },
          "properties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "box": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "minItems": 4,
            "maxItems": 4
          }
        }
      }
    },
    "formula": {
      "$ref": "#/$defs/node"
    }
  },
  "$defs": {
    "node": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "node",
            "name",
            "args"
          ],
          "additionalProperties": false,
          "properties": {
            "node": {
              "const": "rel"
            },
            "name": {
              "enum": [
                "above",
                "below",
                "left",
                "right",
                "cabove",
                "cbelow",
                "cleft",
                "cright",
                "wider",
                "narrower",
                "taller",
                "shorter",
                "xeq",
                "yeq",
                "weq",
                "heq"
              ]
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 2,
              "maxItems": 2
            },
            "const": {
              "type": [
                "integer",
                "null"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "node",
            "name",
            "args",
            "const"
          ],
          "additionalProperties": false,
          "properties": {
            "node": {
              "const": "rel"
            },
            "name": {
              "enum": [
                "above_value",
                "below_value",
                "left_value",
                "right_value",
                "wider_value",
                "narrower_value",
                "taller_value",
                "shorter_value",
                "xeq_value",
                "yeq_value",
                "weq_value",
                "heq_value"
              ]
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "maxItems": 1
            },
            "const": {
              "type": "integer"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "node",
            "obj",
            "type"
          ],
          "additionalProperties": false,
          "properties": {
            "node": {
              "const": "type"
            },
            "obj": {
              "type": "string"
            },
            "type": {
              "enum": [
                "chair",
                "couch",
                "potted plant",
                "bed",
                "mirror",
                "dining table",
                "window",
                "desk",
                "toilet",
                "door",
                "TV",
                "microwave",
                "oven",
                "toaster",
                "sink",
                "refrigerator",
                "blender"
              ]
            }
          }
        },
        {
          "type": "object",
          "required": [
            "node",
            "obj",
            "value"
          ],
          "additionalProperties": false,
          "properties": {
            "node": {
              "const": "property"
            },
            "obj": {
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "node",
            "obj"
          ],
          "additionalProperties": false,
          "properties": {
            "node": {
              "const": "default"
            },
            "obj": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "node",
            "arg"
          ],
          "additionalProperties": false,
          "properties": {
            "node": {
              "const": "not"
            },
            "arg": {
              "$ref": "#/$defs/node"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "node",
            "args"
          ],
          "additionalProperties": false,
          "properties": {
            "node": {
              "const": "and"
            },
            "args": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/node"
              },
              "minItems": 1
            }
          }
        },
        {
          "type": "object",
          "required": [
            "node",
            "args"
          ],
          "additionalProperties": false,
          "properties": {
            "node": {
              "const": "or"
            },
            "args": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/node"
              },
              "minItems": 2
            }
          }
        },
        {
          "type": "object",
          "required": [
            "node",
            "kind",
            "options"
          ],
          "additionalProperties": false,
          "properties": {
            "node": {
              "const": "choice"
            },
            "kind": {
              "enum": [
                "direction",
                "offset",
                "reference",
                "scope",
                "unsupported_type"
              ]
            },
            "span": {
              "type": "string"
            },
            "emphasis": {
              "type": "boolean"
            },
            "options": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": [
                  "prior"
                ],
                "additionalProperties": false,
                "properties": {
                  "prior": {
                    "type": "number"
                  },
                  "formula": {
                    "oneOf": [
                      {
                        "$ref": "#/$defs/node"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "skip": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
